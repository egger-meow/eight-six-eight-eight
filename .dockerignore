# =============================================================================
# .dockerignore — Files excluded from Docker build context
# =============================================================================
# The build context is the monorepo root (set via context: .. in compose).
# Excluding unnecessary files keeps the context small and builds fast.

# Dependencies (rebuilt inside container)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js build output (rebuilt inside container)
**/.next
**/out

# Turbo cache (not needed in build)
.turbo
**/.turbo

# Infrastructure (avoid recursive context — compose lives here)
infra/

# Version control
.git
.gitignore

# Documentation & non-build files
*.md
!README.md

# IDE & editor files
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Environment files (secrets — never bake into image)
.env
.env.*
!.env.example

# Synology NAS artifacts
@eaDir

# Test & coverage
coverage
.nyc_output

# Gemini / AI tooling
.gemini
