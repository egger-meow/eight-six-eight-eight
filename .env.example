# =============================================================================
# 86.88 B&B — Docker Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# IMPORTANT: .env is gitignored. NEVER commit secrets to version control.
#
# This file is read by `docker compose` from the infra/ directory.
# Run: cd infra && docker compose --env-file ../.env up -d
# Or:  symlink from infra/.env → ../.env
# =============================================================================

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Get this from: Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Token
TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# ── Node.js ──────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Used by the postgres container and any app connecting to it
POSTGRES_PASSWORD=changeme

# ── Database URL (for API / Prisma) ──────────────────────────────────────────
# Constructed from the postgres service name in docker-compose
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://8688bnb_user:changeme@postgres:5432/8688bnb

# ── Redis URL (for API / caching) ────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── API Server ───────────────────────────────────────────────────────────────
# Generate secure secrets with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
CSRF_SECRET=
ADMIN_DEFAULT_PASSWORD=8688bnb
WEBHOOK_API_KEY=
API_PORT=3333
CORS_ORIGIN=https://8688bnb.com,https://admin.8688bnb.com

# Browser-reachable public API URLs for Next.js apps
WEBSITE_PUBLIC_API_URL=https://api.8688bnb.com/api/v1
ADMIN_PUBLIC_API_URL=https://api.8688bnb.com/api/v1

